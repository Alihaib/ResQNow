rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function role() {
      return isSignedIn() ? userDoc(request.auth.uid).role : null;
    }

    function isApprovedDoctor() {
      return role() == "doctor" && userDoc(request.auth.uid).approved == true;
    }

    function isApprovedAmbulance() {
      return role() == "ambulance" && userDoc(request.auth.uid).approved == true;
    }

    function isApprovedResponder() {
      return isApprovedDoctor() || isApprovedAmbulance();
    }

    function isAdmin() {
      return role() == "admin";
    }

    function ownerUid() {
      return resource.data.userId;
    }

    function callerCancels() {
      return request.auth.uid == ownerUid()
        && request.resource.data.sessionStatus == "cancelled"
        && request.resource.data.status == "cancelled";
    }

    // Doctors may change only notes/timeline/updatedAt — all incident + dispatch fields locked.
    function doctorMedicalNoteOnly() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.victimType == resource.data.victimType
        && request.resource.data.location == resource.data.location
        && request.resource.data.patientLocation == resource.data.patientLocation
        && request.resource.data.status == resource.data.status
        && request.resource.data.sessionStatus == resource.data.sessionStatus
        && request.resource.data.assignedAmbulanceId == resource.data.assignedAmbulanceId
        && request.resource.data.ambulanceLocation == resource.data.ambulanceLocation
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.currentSnapshot == resource.data.currentSnapshot;
    }

    // Ambulances may change dispatch/GPS/timeline — not patient identity blob or doctor notes.
    function ambulanceOpsOnly() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.victimType == resource.data.victimType
        && request.resource.data.location == resource.data.location
        && request.resource.data.patientLocation == resource.data.patientLocation
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.doctorNotes == resource.data.doctorNotes;
    }

    // currentSnapshot may include clinical fields (symptoms, vitals, conditionLevel) only when on-scene.
    function hasMedicalSnapshotFields(cs) {
      return cs is map && cs.keys().hasAny(['symptoms', 'vitals', 'conditionLevel']);
    }

    function ambulanceSnapshotPhaseOk() {
      return request.resource.data.status == "arrived"
        || !hasMedicalSnapshotFields(request.resource.data.currentSnapshot);
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isApprovedResponder() || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /emergencies/{id} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sessionStatus == "active"
        && request.resource.data.status == "dispatched";

      allow read: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isApprovedResponder()
          || isAdmin()
        );

      allow update: if isSignedIn() && (
          isAdmin()
          || callerCancels()
          || (isApprovedDoctor() && doctorMedicalNoteOnly())
          || (isApprovedAmbulance() && ambulanceOpsOnly() && ambulanceSnapshotPhaseOk())
        );

      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
